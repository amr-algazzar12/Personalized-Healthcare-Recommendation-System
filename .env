# =============================================================================
# .env — gitignored, never commit this file
# All Postgres credentials MUST match the docker-compose.yaml definitions.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (external_postgres_db)
# These are the EXACT credentials set in docker-compose.yaml.
# Do NOT change unless you also change them in the compose file.
# ---------------------------------------------------------------------------
POSTGRES_HOST=external_postgres_db
POSTGRES_PORT=5432
POSTGRES_USER=external
POSTGRES_PASSWORD=external
POSTGRES_DB=external

# Airflow uses a separate DB on the same Postgres instance
AIRFLOW_DB=airflow

# MLflow uses a separate DB on the same Postgres instance
MLFLOW_DB=mlflow

# ---------------------------------------------------------------------------
# pgAdmin — matches docker-compose.yaml exactly
# ---------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=pgadmin@xyz.com
PGADMIN_DEFAULT_PASSWORD=external

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5001
MLFLOW_BACKEND_STORE_URI=postgresql://external:external@external_postgres_db:5432/mlflow
MLFLOW_ARTIFACT_ROOT=/home/mlflow_artifacts

# ---------------------------------------------------------------------------
# Flask API
# ---------------------------------------------------------------------------
FLASK_ENV=development
FLASK_PORT=5050
FLASK_SECRET_KEY=change_this_in_production

# ---------------------------------------------------------------------------
# Spark / YARN
# ---------------------------------------------------------------------------
PYSPARK_PYTHON=/root/anaconda/envs/healthcare-rec/bin/python
PYSPARK_DRIVER_PYTHON=/root/anaconda/envs/healthcare-rec/bin/python